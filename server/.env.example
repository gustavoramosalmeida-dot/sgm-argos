# Copie para `.env` na pasta `server/` e ajuste os valores (nunca commite `.env` com segredos reais).

PORT=3333
NODE_ENV=development

# Uma origem ou várias separadas por vírgula (produção: URL do frontend)
CORS_ORIGIN=http://localhost:5173

# Atrás de Nginx/ALB (recomendado em produção): `1` = confiar num hop de proxy
# TRUST_PROXY=1

# Falha na subida se o Postgres não responder (recomendado em EC2/produção)
# REQUIRE_DB_ON_STARTUP=1

# Opcional: URL completa em vez de PGHOST/PGPORT/... (tem prioridade)
# DATABASE_URL=postgresql://usuario:senha@127.0.0.1:5432/sgm

# Postgres (EC2 local típico: 127.0.0.1:5432)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=sgm
PGUSER=postgres
PGPASSWORD=altere-a-senha

# Opcional: tamanho do pool (default 20)
# PG_POOL_MAX=20

# Base pública da API (URLs de upload persistidas) — sem barra final
# PUBLIC_BASE_URL=https://api.seudominio.com

# JWT (obrigatório em NODE_ENV=production)
# JWT_SECRET=use-um-segredo-longo-aleatorio

# Cookie de sessão: em HTTP (ex.: IP sem TLS) omita ou use 0; com HTTPS na frente use 1
# SGM_AUTH_COOKIE_SECURE=1

# WEB_APP_BASE_URL=https://app.seudominio.com
# WEB_APP_LOGIN_PATH=/login

# Primeiro utilizador (após migrations), na pasta server:
#   SGM_BOOTSTRAP_ADMIN_PASSWORD="senha-forte-8+chars" npm run auth:bootstrap
